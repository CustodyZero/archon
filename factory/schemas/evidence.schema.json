{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://archon.custodyzero.dev/schemas/evidence.schema.json",
  "title": "Archon Factory Environment Evidence",
  "description": "Proof that an environment dependency has been satisfied.",
  "type": "object",
  "required": [
    "dependency_key",
    "verified_at",
    "verified_by",
    "verification_method",
    "description"
  ],
  "properties": {
    "dependency_key": {
      "type": "string",
      "minLength": 1,
      "description": "Must match a key declared in at least one packet's environment_dependencies."
    },
    "verified_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 verification timestamp."
    },
    "verified_by": {
      "type": "object",
      "required": ["kind", "id"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["human", "cli", "ui"],
          "description": "Only human, cli, or ui may verify environment state."
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "verification_method": {
      "type": "string",
      "enum": ["manual", "automated", "ci"],
      "description": "How the dependency was verified."
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "description": "What was verified."
    },
    "proof": {
      "type": ["string", "null"],
      "description": "Supporting evidence (URL, command output, etc.)."
    },
    "expires_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "ISO 8601 expiration. If set, evidence is invalid after this time."
    }
  },
  "additionalProperties": false
}
